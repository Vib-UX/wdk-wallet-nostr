{
  "name": "wdk-wallet-nostr",
  "version": "1.0.0-beta.1",
  "description": "WDK module to create and manage BIP-32 wallets for the nostr blockchain.",
  "keywords": [
    "wdk",
    "wallet",
    "bip-32",
    "nostr"
  ],
  "author": "Vib-UX &lt;vibhav@instaraise.io&gt;",
  "license": "Apache-2.0",
  "main": "index.js",
  "type": "module",
  "types": "./types",
  "scripts": {
    "build:types": "tsc",
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "git:commit": "git -c core.hooksPath=scripts/no-hooks commit -F commitmsg",
    "git:amend": "git -c core.hooksPath=scripts/no-hooks commit --amend -F commitmsg"
  },
  "dependencies": {
    "@scure/bip32": "^2.0.1",
    "@tetherto/wdk-wallet": "^1.0.0-beta.1",
    "bare-node-runtime": "^1.1.4",
    "bip39": "^3.1.0",
    "nostr-tools": "^2.23.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "standard": "^17.1.2",
    "typescript": "^5.8.3"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "bare": "./bare.js",
      "default": "./index.js"
    },
    "./package": {
      "default": "./package.json"
    }
  },
  "standard": {
    "ignore": [
      "bare.js",
      "tests/**/*.js"
    ]
  }
}
